NODE_ENV=development
PORT=8080
CLIENT_ORIGIN=http://localhost:5173
ADMIN_API_KEY=replace_with_long_random_admin_key
AGENT_API_KEY=replace_with_long_random_agent_key

ZENDESK_BASE_URL=https://hotelplanner.zendesk.com
ZENDESK_EMAIL=your_zendesk_email@hotelplanner.com
ZENDESK_API_TOKEN=replace_with_zendesk_token
ZENDESK_WEBHOOK_SECRET=replace_with_zendesk_webhook_secret

OPENAI_API_KEY=replace_with_openai_key
OPENAI_MODEL=gpt-4.1-mini
LLM_ENABLED=false

HP_RESERVATION_API_URL=https://internal-api.hotelplanner.local/reservations
HP_RESERVATION_API_KEY=replace_with_internal_reservation_key
HP_REFUND_API_URL=https://internal-api.hotelplanner.local/refunds
HP_REFUND_API_KEY=replace_with_internal_refund_key
HP_SUPPLIER_API_URL=https://internal-api.hotelplanner.local/suppliers
HP_SUPPLIER_API_KEY=replace_with_internal_supplier_key

RULE_ENGINE_PATH=src/data/rule-engine.json
ADMIN_CONFIG_PATH=src/data/admin-config.json
AUDIT_LOG_PATH=src/data/audit-log.jsonl
